{
  "name": "@NexisClaw/mattermost",
  "version": "2026.5.12-beta.1",
  "description": "NexisClaw Mattermost channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexisClaw/NexisClaw"
  },
  "type": "module",
  "dependencies": {
    "ws": "8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@NexisClaw/plugin-sdk": "workspace:*",
    "NexisClaw": "workspace:*"
  },
  "peerDependencies": {
    "NexisClaw": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "NexisClaw": {
      "optional": true
    }
  },
  "NexisClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "minHostVersion": ">=2026.4.10"
    }
  }
}
