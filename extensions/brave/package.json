{
  "name": "@GreenchClaw/brave-plugin",
  "version": "2026.5.12-beta.1",
  "description": "GreenchClaw Brave plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenchClaw/GreenchClaw"
  },
  "type": "module",
  "devDependencies": {
    "@GreenchClaw/plugin-sdk": "workspace:*"
  },
  "GreenchClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@GreenchClaw/brave-plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "GreenchClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
