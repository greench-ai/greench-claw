{
  "name": "@NexisClaw/voice-call",
  "version": "2026.5.12-beta.1",
  "description": "NexisClaw voice-call plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexisClaw/NexisClaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.38",
    "ws": "8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@NexisClaw/plugin-sdk": "workspace:*",
    "NexisClaw": "workspace:*"
  },
  "peerDependencies": {
    "NexisClaw": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "NexisClaw": {
      "optional": true
    }
  },
  "NexisClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@NexisClaw/voice-call",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "NexisClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
