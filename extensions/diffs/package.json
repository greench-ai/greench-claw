{
  "name": "@GreenchClaw/diffs",
  "version": "2026.5.12-beta.1",
  "description": "GreenchClaw diff viewer plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenchClaw/GreenchClaw"
  },
  "type": "module",
  "scripts": {
    "build:viewer": "bun build src/viewer-client.ts --target browser --format esm --minify --outfile assets/viewer-runtime.js"
  },
  "dependencies": {
    "@pierre/diffs": "1.1.22",
    "@pierre/theme": "0.0.29",
    "playwright-core": "1.60.0",
    "typebox": "1.1.38",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@GreenchClaw/plugin-sdk": "workspace:*"
  },
  "GreenchClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@GreenchClaw/diffs",
      "localPath": "extensions/diffs",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.30"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "GreenchClawVersion": "2026.5.12-beta.1",
      "staticAssets": [
        {
          "source": "./assets/viewer-runtime.js",
          "output": "assets/viewer-runtime.js"
        }
      ]
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
