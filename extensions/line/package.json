{
  "name": "@GreenchClaw/line",
  "version": "2026.5.12-beta.1",
  "description": "GreenchClaw LINE channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenchClaw/GreenchClaw"
  },
  "type": "module",
  "dependencies": {
    "@line/bot-sdk": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@GreenchClaw/plugin-sdk": "workspace:*",
    "GreenchClaw": "workspace:*"
  },
  "peerDependencies": {
    "GreenchClaw": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "GreenchClaw": {
      "optional": true
    }
  },
  "GreenchClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "line",
      "label": "LINE",
      "selectionLabel": "LINE (Messaging API)",
      "detailLabel": "LINE Bot",
      "docsPath": "/channels/line",
      "docsLabel": "line",
      "blurb": "LINE Messaging API webhook bot.",
      "systemImage": "message",
      "order": 75,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@GreenchClaw/line",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "GreenchClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
