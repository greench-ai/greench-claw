{
  "name": "@GreenchClaw/msteams",
  "version": "2026.5.12-beta.1",
  "description": "GreenchClaw Microsoft Teams channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenchClaw/GreenchClaw"
  },
  "type": "module",
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@microsoft/teams.api": "2.0.10",
    "@microsoft/teams.apps": "2.0.10",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@GreenchClaw/plugin-sdk": "workspace:*",
    "@types/jsonwebtoken": "9.0.10",
    "GreenchClaw": "workspace:*"
  },
  "peerDependencies": {
    "GreenchClaw": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "GreenchClaw": {
      "optional": true
    }
  },
  "GreenchClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60,
      "doctorCapabilities": {
        "dmAllowFromMode": "topOnly",
        "groupModel": "hybrid",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": true
      }
    },
    "install": {
      "npmSpec": "@GreenchClaw/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "GreenchClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
