{
  "name": "@GreenchClaw/whatsapp",
  "version": "2026.5.12-beta.1",
  "description": "GreenchClaw WhatsApp channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenchClaw/GreenchClaw"
  },
  "type": "module",
  "dependencies": {
    "baileys": "7.0.0-rc10",
    "https-proxy-agent": "9.0.0",
    "jimp": "1.6.1",
    "typebox": "1.1.38",
    "undici": "8.2.0"
  },
  "devDependencies": {
    "@GreenchClaw/plugin-sdk": "workspace:*",
    "GreenchClaw": "workspace:*"
  },
  "peerDependencies": {
    "GreenchClaw": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "GreenchClaw": {
      "optional": true
    }
  },
  "GreenchClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "setupFeatures": {
      "legacyStateMigrations": true,
      "legacySessionSurfaces": true
    },
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message",
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyWhatsAppAuth"
      },
      "cliAddOptions": [
        {
          "flags": "--auth-dir <path>",
          "description": "WhatsApp auth directory override"
        }
      ]
    },
    "install": {
      "npmSpec": "@GreenchClaw/whatsapp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "GreenchClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
