{
  "name": "@NexisClaw/diagnostics-prometheus",
  "version": "2026.5.12-beta.1",
  "description": "NexisClaw diagnostics Prometheus exporter",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexisClaw/NexisClaw"
  },
  "type": "module",
  "devDependencies": {
    "@NexisClaw/plugin-sdk": "workspace:*"
  },
  "NexisClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@NexisClaw/diagnostics-prometheus",
      "npmSpec": "@NexisClaw/diagnostics-prometheus",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "NexisClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
