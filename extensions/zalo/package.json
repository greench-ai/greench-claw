{
  "name": "@NexisClaw/zalo",
  "version": "2026.5.12-beta.1",
  "description": "NexisClaw Zalo channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexisClaw/NexisClaw"
  },
  "type": "module",
  "devDependencies": {
    "@NexisClaw/plugin-sdk": "workspace:*",
    "NexisClaw": "workspace:*"
  },
  "peerDependencies": {
    "NexisClaw": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "NexisClaw": {
      "optional": true
    }
  },
  "NexisClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@NexisClaw/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "NexisClawVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
